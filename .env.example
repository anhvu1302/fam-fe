# Environment Configuration Template
# Copy to .env.local and fill in the values

NODE_ENV=development

# ==================== CORE ====================
PORT=8001

# ==================== BACKEND & STORAGE ====================
# Backend API URL (Server-side only - không lộ ra client)
BACKEND_API_URL=http://localhost:8000
# BACKEND_API_URL=https://api.fam.codes

# MinIO/S3 URL (used to construct file URLs for displaying images)
NEXT_PUBLIC_MINIO_URL=http://localhost:9000
# NEXT_PUBLIC_MINIO_URL=https://minio.fam.codes

# ==================== SECURITY: ENCRYPTION & REPLAY PROTECTION ====================
# Crypto key for payload encryption (Client + Server)
NEXT_PUBLIC_CRYPTO_KEY="CHANGE_ME_generate_with_openssl_rand_base64_32"

# Enable/Disable encryption (true/false) - Set "false" for debug mode
NEXT_PUBLIC_ENABLE_ENCRYPTION=true

# Enable/Disable compression before encryption (true/false)
NEXT_PUBLIC_ENABLE_COMPRESSION=true

# Max age for request timestamp (milliseconds)
# Default: 300000 (5 minutes)
NEXT_PUBLIC_MAX_REQUEST_AGE=300000

# ==================== SECURITY: DIRECT ACCESS PROTECTION ====================
# App signature secret key (for authenticating app requests)
# Generate with: openssl rand -base64 32
# ⚠️ IMPORTANT: Keep this secret! Don't share or commit to git
NEXT_PUBLIC_APP_SIGNATURE_KEY="CHANGE_ME_generate_with_openssl_rand_base64_32"

# Allowed origins (comma separated) - domains that can call the API proxy
# Add your production domain here
ALLOWED_ORIGINS="http://localhost:8001,http://localhost:3000"